# Extractor (HTTP service)
PORT=8090
MAX_TEXT_LENGTH=4000
REQUEST_TIMEOUT=15

# Postgres
DATABASE_URL=postgresql://postgres:PASSWORD@192.168.0.89:5432/mcp_news

# Pipeline
SOURCES_FILE=/app/config/sources.yaml
SUMMARIES_DIR=summaries
FETCH_CONCURRENCY=4
FETCH_DELAY_SECONDS=1
# Only extract items published within this many hours (items with no
# publish timestamp — e.g. scraped index pages — are always accepted).
FETCH_WINDOW_HOURS=24

# Summary prompt cap measured in the provider's native tokens. 850K
# leaves a safe buffer under Gemini's 1M-token context window; lower
# for Claude (~200K) or small OpenAI models.
SUMMARY_TOKEN_CAP=850000

# Only include articles published (or uploaded, if publish date is
# missing) within this many hours of the summarize run.
SUMMARY_WINDOW_HOURS=24

# LLM — set LLM_PROVIDER to one of: claude | openai | gemini | openrouter
# and fill in that provider's API key.
LLM_PROVIDER=gemini
# LLM_MODEL=                    # optional override; else provider default
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# OpenRouter routing (only used when LLM_PROVIDER=openrouter).
# Comma-separated list of upstream provider slugs (e.g. "deepseek") to
# pin requests to specific infrastructure — useful for cost control,
# since OpenRouter otherwise picks any available host. Leave empty to
# use OpenRouter's default routing.
# When ALLOW_FALLBACKS=false (default) and ORDER is set, requests fail
# rather than spilling to a non-pinned upstream.
# Example pinning DeepSeek V4 Pro to DeepSeek's own infra:
#   LLM_PROVIDER=openrouter
#   LLM_MODEL=deepseek/deepseek-v4-pro
#   OPENROUTER_PROVIDER_ORDER=deepseek
OPENROUTER_PROVIDER_ORDER=
OPENROUTER_ALLOW_FALLBACKS=false
# Optional attribution shown on OpenRouter's leaderboards.
OPENROUTER_APP_URL=
OPENROUTER_APP_TITLE=

# Briefing
NTFY_TOPIC=
PRINT_QUEUE=brother
BRIEFING_CATEGORIES_FILE=config/briefing_categories.yaml
BRIEFINGS_DIR=briefings

# --- Briefing live-data keys (all optional; each falls back to stub
#     values if unset) ---
# OpenWeatherMap (legacy /data/2.5 endpoints). Free tier.
WEATHER_API_KEY=
# Finnhub /api/v1/quote. Free tier covers SPY/QQQ/TQQQ + BINANCE:BTCUSDT.
STOCK_API_KEY=
# Federal Reserve Economic Data. Free; request a key at
# https://fred.stlouisfed.org/docs/api/api_key.html.
FRED_API_KEY=

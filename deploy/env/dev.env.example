# Dev-environment .env template — deltas from prod (deploy/env/prod.env.example)
# are marked. Copy to the dev checkout's .env and fill in.

# Extractor (HTTP service) — distinct port so it can run beside prod's 8090
PORT=8091
MAX_TEXT_LENGTH=4000
REQUEST_TIMEOUT=15

# Postgres — dev database, NOT mcp_news
DATABASE_URL=postgresql://postgres:PASSWORD@192.168.0.89:5432/mcp_news_dev
# Test suite DB (shared with prod checkout; tests truncate it)
TEST_DATABASE_URL=postgresql://postgres:PASSWORD@192.168.0.89:5432/jina_clone_test

# Pipeline — host path (the /app/... path is for in-container runs; the
# dev fetch is run manually from the checkout)
SOURCES_FILE=config/sources.yaml
FETCH_CONCURRENCY=4
FETCH_DELAY_SECONDS=1
FETCH_WINDOW_HOURS=24

# LLM
LLM_PROVIDER=gemini

# Briefing — no ntfy alerts from dev, distinct feed output dir,
# physical printing stays off (print_enabled=False in code anyway).
NTFY_TOPIC=
PRINT_QUEUE=brother
BRIEFING_CATEGORIES_FILE=config/briefing_categories.yaml
BRIEFINGS_DIR=briefings

# Live-data keys optional — stubs used when unset
WEATHER_API_KEY=
STOCK_API_KEY=
FRED_API_KEY=

# Feed — dev output dir; leave FEED_BASE_URL unset unless a dev vhost exists
FEED_BASE_URL=
FEED_OUTPUT_DIR=feeds-dev/ai-digest

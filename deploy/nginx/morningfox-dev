# Dev preview of themorningfox.com — LAN-only (port 8081 is not
# port-forwarded). Serves the jina-clone-dev checkout.
server {
    listen 8081;
    server_name _;
    root /home/elucia/dev/jina-clone-dev/web;
    index index.html;
    autoindex off;

    include snippets/security-headers.conf;
    include snippets/deny-dotfiles.conf;
    include snippets/error-pages.conf;

    location / { try_files $uri $uri/ =404; }
    location /editions/ { alias /home/elucia/dev/jina-clone-dev/briefings/; }
}

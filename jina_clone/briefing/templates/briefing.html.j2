<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ title }} — {{ date }}</title>
<style>
  @font-face {
    font-family: 'Bodoni Moda';
    src: url('../static/fonts/BodoniModa-Regular.ttf') format('truetype');
    font-weight: 400;
  }
  @font-face {
    font-family: 'Bodoni Moda';
    src: url('../static/fonts/BodoniModa-Medium.ttf') format('truetype');
    font-weight: 500;
  }

  @page {
    size: letter;
    margin: 0.4in 0.4in 0.55in 0.4in;

    @bottom-left {
      content: "Briefing run · {{ iso_date }}";
      font-size: 8pt;
      color: #777;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding-top: 4px;
      border-top: 0.5px solid #aaa;
      vertical-align: top;
    }
    @bottom-right {
      content: "{{ title }} · Page " counter(page);
      font-size: 8pt;
      color: #777;
      text-transform: uppercase;
      letter-spacing: 1px;
      text-align: right;
      padding-top: 4px;
      border-top: 0.5px solid #aaa;
      vertical-align: top;
    }
  }

  html, body {
    margin: 0;
    padding: 0;
    color: #1a1a1a;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .masthead {
    border-bottom: 3px double #1a1a1a;
    padding-bottom: 10px;
    margin-bottom: 14px;
  }
  .masthead-title {
    font-family: 'Bodoni Moda', Georgia, serif;
    font-size: 40pt;
    font-weight: 500;
    letter-spacing: 1px;
    text-align: center;
    margin: 0;
    line-height: 1;
    color: #1a1a1a;
  }
  .masthead-meta {
    display: flex;
    justify-content: space-between;
    font-size: 9pt;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    margin-top: 8px;
    color: #555;
  }
  .weather-strip {
    display: flex;
    gap: 18px;
    font-size: 9pt;
    margin-top: 4px;
    justify-content: center;
  }
  .weather-strip strong {
    font-weight: 500;
    color: #1a1a1a;
  }

  .lead {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 14px;
    padding-bottom: 8px;
    border-bottom: 0.5px solid #888;
    margin-bottom: 10px;
  }
  .lead-headline {
    font-family: Georgia, serif;
    font-size: 20pt;
    font-weight: 500;
    line-height: 1.15;
    margin: 0 0 6px;
    color: #1a1a1a;
  }
  .lead-deck {
    font-size: 10pt;
    color: #555;
    font-style: italic;
    margin: 0 0 8px;
    line-height: 1.35;
  }
  .lead-body {
    font-size: 9.5pt;
    line-height: 1.35;
    column-count: 2;
    column-gap: 12px;
    text-align: justify;
    hyphens: auto;
    margin: 0;
  }
  .lead-sidebar {
    font-size: 9pt;
    line-height: 1.4;
    background: transparent;
    padding: 8px 10px;
    border-left: 2px solid #1a1a1a;
  }
  .lead-sidebar-title {
    font-size: 9pt;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
    margin: 0 0 4px;
    color: #1a1a1a;
  }
  .lead-sidebar ul { margin: 0; padding-left: 14px; }
  .lead-sidebar li { margin-bottom: 3px; }

  .section-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 6px;
  }
  .panel {
    border-top: 1.5px solid #1a1a1a;
    padding-top: 6px;
    break-inside: avoid-page;
  }
  .panel-title {
    font-family: Georgia, serif;
    font-size: 11pt;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 500;
    margin: 0 0 4px;
    color: #1a1a1a;
  }
  .panel-lede {
    font-family: Georgia, serif;
    font-size: 12pt;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 4px;
    color: #1a1a1a;
  }
  .panel-body {
    font-size: 9pt;
    line-height: 1.35;
    margin: 0;
    text-align: justify;
    hyphens: auto;
    color: #1a1a1a;
  }
  .panel-also {
    border-top: 0.3px solid #888;
    margin-top: 6px;
    padding-top: 4px;
  }
  .panel-item {
    font-size: 8.5pt;
    line-height: 1.3;
    margin-bottom: 3px;
    color: #1a1a1a;
  }
  .panel-item strong {
    font-weight: 500;
  }

  .pull-quote {
    font-family: Georgia, serif;
    font-style: italic;
    font-size: 12pt;
    line-height: 1.3;
    text-align: center;
    padding: 6px 18px;
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
    margin: 8px 0;
    color: #1a1a1a;
  }

  .three-col {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 12px;
  }
  .brief-item {
    font-size: 9pt;
    line-height: 1.35;
    color: #1a1a1a;
    margin-bottom: 8px;
    break-inside: avoid;
  }
  .brief-item strong {
    display: block;
    font-weight: 500;
    font-size: 10pt;
    margin-bottom: 2px;
    color: #1a1a1a;
  }
</style>
</head>
<body>
{% set include_extras = include_extras | default(true) %}

<div class="masthead">
  <h1 class="masthead-title">{{ title }}</h1>
  <div class="masthead-meta">
    <span>{{ volume }}</span>
    <span>{{ date }}</span>
    <span>{{ location }}</span>
  </div>
  <div class="weather-strip">
    <span><strong>{{ weather.temp_high }}° / {{ weather.temp_low }}°</strong> {{ weather.conditions }}</span>
    <span><strong>Sunrise</strong> {{ weather.sunrise }}</span>
    <span><strong>Sunset</strong> {{ weather.sunset }}</span>
    <span><strong>Pollen</strong> {{ weather.pollen }}</span>
  </div>
</div>

<div class="lead">
  <div>
    <h2 class="lead-headline">{{ lead.headline }}</h2>
    <p class="lead-deck">{{ lead.deck }}</p>
    <p class="lead-body">{{ lead.body }}</p>
  </div>
  <aside class="lead-sidebar">
    <p class="lead-sidebar-title">At a glance</p>
    <ul>
      {% for item in lead.at_a_glance %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </aside>
</div>

<div class="section-grid">
  {% for panel in panels[:2] %}
  <div class="panel">
    <h3 class="panel-title">{{ panel.section }}</h3>
    <p class="panel-lede">{{ panel.lede_headline }}</p>
    <p class="panel-body">{{ panel.lede_body }}</p>
    <div class="panel-also">
      {% for item in panel.also %}
      <div class="panel-item">
        <strong>{{ item.headline }}</strong> {{ item.body }}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</div>

<div class="pull-quote">
  "{{ pull_quote }}"
</div>

<div class="section-grid">
  {% for panel in panels[2:] %}
  <div class="panel">
    <h3 class="panel-title">{{ panel.section }}</h3>
    <p class="panel-lede">{{ panel.lede_headline }}</p>
    <p class="panel-body">{{ panel.lede_body }}</p>
    <div class="panel-also">
      {% for item in panel.also %}
      <div class="panel-item">
        <strong>{{ item.headline }}</strong> {{ item.body }}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endfor %}
</div>

<div class="panel" style="margin-top: 10px; margin-bottom: 12px;">
  <h3 class="panel-title">Briefs · what else happened</h3>
  <div class="three-col" style="margin-top: 6px;">
    {% for brief in briefs %}
    <div class="brief-item">
      <strong>{{ brief.topic }}</strong>
      {{ brief.body }}
    </div>
    {% endfor %}
  </div>
</div>

{% if include_extras %}
<div class="section-grid">
  <div class="panel">
    <h3 class="panel-title">Data point of the day</h3>
    <p class="panel-lede">{{ data_point.value }}</p>
    <p class="panel-body">{{ data_point.context }}</p>
  </div>
  <div class="panel">
    <h3 class="panel-title">On this day</h3>
    <p class="panel-lede">{{ on_this_day.year_and_title }}</p>
    <p class="panel-body">{{ on_this_day.body }}</p>
  </div>
</div>
{% endif %}

</body>
</html>
